<% if user_signed_in? %>
  <p style="color: green"><%= notice %></p>

  <% content_for :title, "Friends" %>

  <h1>Friends</h1>

  <table class="table table-striped table-bordered table-hover">
    <thead>
      <tr>
        <th>Name</th>
        <th>Twitter</th>
        <th>Email</th>
        <th>Phone number</th>
        <th>id</th>
        
      </tr>
    </thead>

    <tbody>
      <% @friends.each do |friend| %>
        <tr>
          <td><%= link_to friend.first_name + ' ' + friend.second_name, friend %> </td>
          <td><%= friend.twitter %></td>
          <td><%= friend.email %></td>
          <td><%= friend.phone_num %></td>
          <td><%= friend.id %></td>
          <td>
            <!-- <%= link_to "Show", friend, class: "btn btn-sm btn-primary" %> -->
            <!-- <%= link_to "Edit", edit_friend_path(friend), class: "btn btn-sm btn-warning" %> -->
            <%= link_to "Destroy", friend, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-danger" %>
        
        

          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%= link_to "New Friend", new_friend_path, class: "btn btn-success" %>
<%else%>  
<h1>
  You are not logged in
</h1>
<%end%>