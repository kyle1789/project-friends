<p style="color: green"><%= notice %></p>


<div class="p-5 mb-4 bg-light rounded-3">
  <div class="container-fluid py-5">
    <h1 class="display-5 fw-bold"><%= @friend.first_name %> <%= @friend.second_name %></h1>
    <p class="col-md-8 fs-4"> <%= @friend.email %> || <%= @friend.phone_num %> || <%= @friend.twitter %> </p>
    <!-- <a class="btn btn-primary btn-lg" href="/friends/new">Add friend</a> -->
  </div>

  <%= link_to "Edit this friend", edit_friend_path(@friend), class: "btn btn-secondary" %> |
  <%= link_to "Back to friends", friends_path, class: "btn btn-secondary" %> 
  <!-- <%= button_to "Destroy this friend", @friend, method: :delete, class: "btn btn-danger" %> -->
</div>
